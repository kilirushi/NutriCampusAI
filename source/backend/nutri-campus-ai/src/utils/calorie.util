const calculateCalories = (height_cm, weight_kg) => {
  const height_m = height_cm / 100;
  const bmi = weight_kg / (height_m ** 2);

  let dailyCalories = 2000;
  if (bmi < 18.5) dailyCalories = 2200;
  else if (bmi < 25) dailyCalories = 2000;
  else if (bmi < 30) dailyCalories = 1800;
  else dailyCalories = 1600;

  return {
    bmi: Number(bmi.toFixed(1)),
    dailyCalories
  };
};

module.exports = { calculateCalories };
