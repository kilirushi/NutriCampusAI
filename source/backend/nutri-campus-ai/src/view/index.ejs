<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - NutriCampusAI</title>
    <link rel="stylesheet" href="index.css" />
  </head>
  <body>
    <div class="layout">
      <!-- Sidebar -->
      <aside class="sidebar">
        <a class="brand" href="#" id="nav-home">NutriCampusAI</a>

        <nav class="side-nav" aria-label="Sidebar navigation">
          <a class="side-link is-active" href="#" id="nav-mealplans"
            >Rate All Time</a
          >
          <a class="side-link" href="#" id="nav-rates">Rate Weekly</a>
          <!-- <a class="side-link" href="#" id="nav-reports">Reports</a> -->
        </nav>
      </aside>

      <!-- Main -->
      <main class="main">
        <!-- Top bar -->
        <header class="topbar">
          <div class="page-title" id="pageTitle">Rate All Time</div>
          <div class="welcome">Welcome, Admin</div>
        </header>

        <!-- Cards area -->
        <section class="stats" aria-label="Dashboard cards">
          <% const mealOrder = ["Breakfast", "Lunch", "Dinner"]; %>

          <!-- HOME / MEAL PLANS VIEW -->
          <div class="view is-active" id="view-home">
            <article class="card dish-card">
              <h3>Top Dishes (All Time)</h3>
              <% if (!topDishes) { %>
              <p class="empty">No rating data yet.</p>
              <% } else { %>
              <% mealOrder.forEach((meal) => { const dishes = topDishes[meal] || []; %>
              <div class="meal-group">
                <h4><%= meal %></h4>
                <% if (!dishes.length) { %>
                <p class="empty">No dishes.</p>
                <% } else { %>
                <ul class="dish-list">
                  <% dishes.forEach((dish) => { %>
                  <li>
                    <span class="dish-name">[⭐ <%= dish.average %>] <%= dish.dish %></span>
                    <span class="dish-meta"
                      >Votes <%= dish.totalVotes %></span
                    >
                  </li>
                  <% }) %>
                </ul>
                <% } %>
              </div>
              <% }) %>
              <% } %>
            </article>

            <article class="card dish-card">
              <h3>Disliked Dishes (All Time)</h3>
              <% if (!bottomDishes) { %>
              <p class="empty">No rating data yet.</p>
              <% } else { %>
              <% mealOrder.forEach((meal) => { const dishes = bottomDishes[meal] || []; %>
              <div class="meal-group">
                <h4><%= meal %></h4>
                <% if (!dishes.length) { %>
                <p class="empty">No dishes.</p>
                <% } else { %>
                <ul class="dish-list">
                  <% dishes.forEach((dish) => { %>
                  <li>
                    <span class="dish-name">[⭐ <%= dish.average %>] <%= dish.dish %></span>
                    <span class="dish-meta"
                      >Votes <%= dish.totalVotes %></span
                    >
                  </li>
                  <% }) %>
                </ul>
                <% } %>
              </div>
              <% }) %>
              <% } %>
            </article>
          </div>

          <!-- RATES VIEW -->
          <div class="view" id="view-rates">
            <article class="card dish-card">
              <h3>Top Dishes (This Week)</h3>
              <% if (!topDishesWeekly) { %>
              <p class="empty">No weekly rating data yet.</p>
              <% } else { %>
              <% mealOrder.forEach((meal) => { const dishes = topDishesWeekly[meal] || []; %>
              <div class="meal-group">
                <h4><%= meal %></h4>
                <% if (!dishes.length) { %>
                <p class="empty">No dishes.</p>
                <% } else { %>
                <ul class="dish-list">
                  <% dishes.forEach((dish) => { %>
                  <li>
                    <span class="dish-name">[⭐ <%= dish.average %>] <%= dish.dish %></span>
                    <span class="dish-meta"
                      >Votes <%= dish.totalVotes %></span
                    >
                  </li>
                  <% }) %>
                </ul>
                <% } %>
              </div>
              <% }) %>
              <% } %>
            </article>

            <article class="card dish-card">
              <h3>Disliked Dishes (This Week)</h3>
              <% if (!bottomDishesWeekly) { %>
              <p class="empty">No weekly rating data yet.</p>
              <% } else { %>
              <% mealOrder.forEach((meal) => { const dishes = bottomDishesWeekly[meal] || []; %>
              <div class="meal-group">
                <h4><%= meal %></h4>
                <% if (!dishes.length) { %>
                <p class="empty">No dishes.</p>
                <% } else { %>
                <ul class="dish-list">
                  <% dishes.forEach((dish) => { %>
                  <li>
                    <span class="dish-name">[⭐ <%= dish.average %>] <%= dish.dish %></span>
                    <span class="dish-meta"
                      >Votes <%= dish.totalVotes %></span
                    >
                  </li>
                  <% }) %>
                </ul>
                <% } %>
              </div>
              <% }) %>
              <% } %>
            </article>
          </div>
        </section>
      </main>
    </div>

    <script src="switch.js"></script>
  </body>
</html>
